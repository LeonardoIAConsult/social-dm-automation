# ─────────────────────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────
# Meta / Instagram  (ver docs/SETUP_META.md para obtener cada valor)
# ─────────────────────────────────────────────────────────────

# Token que TU inventas. Debe coincidir con el que pones en el panel
# de Meta al configurar el webhook (campo "Verify Token").
META_WEBHOOK_VERIFY_TOKEN=pon-aqui-una-cadena-secreta-larga

# App Secret de tu app en developers.facebook.com (App Settings > Basic).
# Se usa para validar la firma X-Hub-Signature-256 de cada webhook.
META_APP_SECRET=

# Access token de larga duracion de la cuenta profesional de Instagram
# (o de la Pagina vinculada). Permiso requerido: instagram_business_manage_messages.
IG_ACCESS_TOKEN=

# ID de tu cuenta profesional de Instagram (Instagram-scoped o Page-scoped segun setup).
IG_BUSINESS_ACCOUNT_ID=

# Version del Graph API a usar.
GRAPH_API_VERSION=v21.0

# ─────────────────────────────────────────────────────────────
# Comportamiento del follow-gate
# ─────────────────────────────────────────────────────────────
# Si true, se exige que la persona siga la cuenta antes de entregar el valor.
FOLLOW_GATE_ENABLED=true

# ─────────────────────────────────────────────────────────────
# Pruebas locales (DRY_RUN) — no llama al Graph API real
# ─────────────────────────────────────────────────────────────
DRY_RUN=false
# En dry-run, respuestas simuladas del Graph API:
SIM_IS_FOLLOWER=true
SIM_CAPTION=Comenta "GUIA" y te la mando

# ─────────────────────────────────────────────────────────────
# Helper de token (execution/meta_token_setup.mjs) — opcional
# ─────────────────────────────────────────────────────────────
IG_APP_ID=
IG_SHORT_TOKEN=
